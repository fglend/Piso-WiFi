# Flask
FLASK_ENV=development  # development or production
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
SECRET_KEY=your-secret-key-here  # REQUIRED: change before production; app refuses defaults in production

# Admin Access
ADMIN_USERNAME=admin
# Preferred: a werkzeug password hash. Generate with:
#   python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('yourpassword'))"
ADMIN_PASSWORD_HASH=
# Fallback plaintext password (used only when ADMIN_PASSWORD_HASH is empty)
ADMIN_PASSWORD=gdfADMIN100424:  # Change this! App refuses this default in production

# Pricing: minutes of access per peso
RATE_MINUTES_PER_PESO=5

# UI defaults. Admin dashboard settings can override these at runtime.
PORTAL_TITLE=PISO WIFI Portal
PORTAL_SUBTITLE=Only one phone can use the coin slot at a time.
DASHBOARD_REFRESH_SECONDS=10
DEFAULT_DOWNLOAD_KBPS=2048
DEFAULT_UPLOAD_KBPS=1024

# Database
DB_PATH=config/piso_wifi.db

# Network interfaces
# Set false for local Docker/web-only testing. Keep true on Orange Pi hardware.
MANAGE_HARDWARE=true
# Optional local-only fallback used when MANAGE_HARDWARE=false and the portal
# cannot resolve a browser request to a real client MAC.
DEV_FAKE_MAC=
WIFI_INTERFACE=wlan0
INTERNET_INTERFACE=wlan1

# WiFi Access Point
AP_SSID=PisoWiFi
AP_PASSWORD=pisowifi123
AP_IP=192.168.4.1
DHCP_RANGE_START=192.168.4.2
DHCP_RANGE_END=192.168.4.254
NETWORK_MASK=255.255.255.0

# Time manager
CHECK_INTERVAL=5           # seconds between metering checks
PAUSE_ON_DISCONNECT=true   # freeze balance when a device disconnects

# Logging
LOG_LEVEL=INFO

# Network mode: 'wired' = Pi is a wired gateway behind an external AP/PoE router
# in bridge mode (Orange Pi PC + USB-to-LAN setup); 'ap' = Pi broadcasts its own
# hotspot via hostapd.
NETWORK_MODE=wired
# Client-side (LAN) interface in wired mode (onboard Ethernet). The USB-to-LAN
# adapter is the INTERNET_INTERFACE (often eth1 or enx<mac> on Armbian - check
# with `ip link`).
LAN_INTERFACE=eth0
INTERNET_INTERFACE=eth1

# Coinslot (GPIO pulse type, e.g. CH-926 / Weiyu universal). COIN/SIG wire ->
# GPIO pin, GND -> GND. COINSLOT_GPIO is the sysfs GPIO number
# (Orange Pi PC: PA6 = 6).
COINSLOT_ENABLED=true
COINSLOT_GPIO=6
COINSLOT_PULSES_PER_PESO=1
COINSLOT_CLAIM_TIMEOUT=60   # seconds a device holds the slot after tapping Insert Coin
COINSLOT_DEBOUNCE_MS=50

# Relay that switches 12V power to the coin acceptor - energized only while a
# claim is active (Insert Coin tapped), so the acceptor is electrically dead
# the rest of the time. COINSLOT_RELAY_GPIO is the sysfs GPIO number
# (Orange Pi PC: PA7 = 7). Wire the relay's NO+COM contacts in series with the
# acceptor's 12V feed (not NC) so a de-energized/unpowered relay = no power to
# the acceptor - a hardware fail-safe if the app crashes or hasn't started.
COINSLOT_RELAY_GPIO=7
# true only if your relay board energizes when IN is driven HIGH; most cheap
# opto-isolated boards are active-LOW (default here).
COINSLOT_RELAY_ACTIVE_HIGH=false
